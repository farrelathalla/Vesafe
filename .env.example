# ============================================================
# VeSafe — Environment Variables
# Microsoft AI Impact Challenge (Dicoding × Komdigi)
# ============================================================
# Copy this file to .env and fill in your values.
# For a no-key local run: set MEDSENTINEL_USE_SYNTHETIC_FALLBACKS=true

# ── InterSystems IRIS ─────────────────────────────────────────
MEDSENTINEL_IRIS_MODE=memory
IRIS_IMAGE=intersystems/irishealth-community:latest-cd
IRIS_HOST=localhost
IRIS_PORT=1972
IRIS_NAMESPACE=MEDSENT
IRIS_USER=medsent_app
IRIS_PASSWORD=<set in secrets manager>
IRIS_FHIR_BASE=http://localhost:52773/fhir/r4
MEDSENT_FHIR_PATH=/fhir/r4
MEDSENT_FHIR_METADATA_PACKAGE=hl7.fhir.r4.core@4.0.1
MEDSENT_FHIR_STRATEGY_CLASS=HS.FHIRServer.Storage.Json.InteractionsStrategy
MEDSENT_SERVER_NAME=VeSafeFHIR
MEDSENT_WALLET_COLLECTION=VeSafe

# ── Azure OpenAI (PRIMARY AI SERVICE — CSE synthesis) ─────────
# Required for live Azure OpenAI usage. Falls back to OpenAI direct or synthetic.
# Get from: Azure Portal → Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<azure openai api key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Azure Blob Storage (3D asset storage) ────────────────────
# Replaces Cloudflare R2. Get from: Azure Portal → Storage Account → Access keys
AZURE_STORAGE_ACCOUNT=<storage account name>
AZURE_STORAGE_KEY=<storage account access key>
AZURE_STORAGE_CONTAINER=vesafe-assets

# ── Azure Web PubSub (real-time WebSocket) ───────────────────
# Get from: Azure Portal → Web PubSub resource → Keys
AZURE_WEB_PUBSUB_CONNECTION_STRING=Endpoint=https://<name>.webpubsub.azure.com;AccessKey=<key>;Version=1.0;
AZURE_WEB_PUBSUB_HUB=vesafe

# ── Azure Application Insights (telemetry) ───────────────────
# Get from: Azure Portal → Application Insights resource → Overview → Connection String
NEXT_PUBLIC_AZURE_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://...
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://...

# ── Azure Maps (facility map — replaces Mapbox) ──────────────
# Get from: Azure Portal → Azure Maps account → Authentication → Primary Key
NEXT_PUBLIC_AZURE_MAPS_KEY=<azure maps subscription key>

# ── Google APIs (public imagery acquisition) ─────────────────
# Enable: Street View Static API + Places API + Geocoding API
GOOGLE_API_KEY=<Maps Platform key>
GOOGLE_GEOCODING_API_KEY=<optional separate geocoding key>

# ── World Labs (3D Gaussian-splat model generation) ──────────
WORLD_LABS_API_KEY=<world labs api key>
WORLD_LABS_API_BASE=https://api.worldlabs.ai

# ── Anthropic Claude (image classification + agent teams) ────
ANTHROPIC_API_KEY=<anthropic api key>

# ── OpenAI direct (fallback if Azure OpenAI not configured) ──
OPENAI_API_KEY=<openai api key>

# ── Modal (serverless A10G GPU for agent inference) ──────────
MODAL_TOKEN_ID=<modal token id>
MODAL_TOKEN_SECRET=<modal token secret>

# ── Redis (fallback if Azure Web PubSub not configured) ──────
REDIS_URL=rediss://<upstash-url>:6380
REDIS_PASSWORD=<upstash password>

# ── Auth ──────────────────────────────────────────────────────
AUTH_SECRET=<auth secret>
AUTH_GOOGLE_ID=<google oauth client id>
AUTH_GOOGLE_SECRET=<google oauth client secret>

# ── Local runtime ─────────────────────────────────────────────
# Set to true to skip all external API calls and use deterministic K3 findings
MEDSENTINEL_USE_SYNTHETIC_FALLBACKS=false

# ── Next.js public vars ───────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
